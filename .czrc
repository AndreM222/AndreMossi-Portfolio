{
      "path": "cz-conventional-changelog",
      "types": {
        "feat": {
          "description": "New user-facing feature",
          "title": "Features"
        },
        "fix": {
          "description": "Bug fixes",
          "title": "Fixes"
        },
        "perf": {
          "description": "Performance improvements",
          "title": "Performance"
        },
        "refactor": {
          "description": "Code changes that neither fix a bug nor add a feature",
          "title": "Refactor"
        },
        "docs": {
          "description": "Documentation only changes",
          "title": "Documentation"
        },
        "style": {
          "description": "Changes that do not affect the meaning of the code (formatting, etc)",
          "title": "Style"
        },
        "chore": {
          "description": "Other changes that don't modify source or test files",
          "title": "Chore"
        },
        "intern": {
          "description": "Internship experience updates",
          "title": "Intern"
        },
        "research": {
          "description": "Research experience updates",
          "title": "Research"
        },
        "awards": {
          "description": "New awards",
          "title": "Awards"
        },
        "certifications": {
          "description": "New certifications",
          "title": "Certifications"
        },
        "projects": {
          "description": "Portfolio project updates",
          "title": "Projects"
        },
        "timeline": {
          "description": "Career timeline updates",
          "title": "Timeline"
        },
        "about": {
          "description": "Personal info/about page updates",
          "title": "About"
        },
        "resume-en": {
          "description": "English resume updates",
          "title": "Resume English"
        },
        "resume-es": {
          "description": "Spanish resume updates",
